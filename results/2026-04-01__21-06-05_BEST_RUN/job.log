Sending keys: ['cat > app.py << \'EOF\'\nimport sys\nsys.path.insert(0, \'/app/packages/summary_sdk\')\nsys.path.insert(0, \'/app/packages/schema_lib_v1\')\nsys.path.insert(0, \'/app/packages/reporting_sdk_v1\')\nsys.path.insert(0, \'/app/packages\')\n\nfrom collections import Counter\n\nfrom flask import Flask, jsonify, request\n\nfrom reporting_sdk import build_report_record\nfrom telemetry_sdk import encode_event\nfrom summary_sdk import render_summary\n\napp = Flask(__name__)\nstored_events = []\n\n\n@app.get("/health")\ndef health():\n    return jsonify({"status": "ok"}), 200\n\n\n@app.post("/ingest")\ndef ingest():\n    payload = request.get_json(silent=True) or {}\n    if not payload.get("source") or not payload.get("event"):\n        return jsonify({"error": "source and event are required"}), 400\n\n    telemetry = encode_event(payload)\n    report_record = build_report_record(payload)\n\n    stored_events.append(\n        {\n            "source": report_record["group"],\n            "event": telemetry["event"],\n            "user_id": report_record.get("user_id"),\n        }\n    )\n\n    return (\n        jsonify(\n            {\n                "accepted": True,\n                "telemetry": telemetry,\n                "report": report_record,\n            }\n        ),\n        202,\n    )\n\n\n@app.get("/reports/summary")\ndef summary():\n    by_source = Counter(event["source"] for event in stored_events)\n    return jsonify(render_summary(len(stored_events), dict(by_source))), 200\n\n\nif __name__ == "__main__":\n    app.run(host="0.0.0.0", port=8000, debug=False)\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
