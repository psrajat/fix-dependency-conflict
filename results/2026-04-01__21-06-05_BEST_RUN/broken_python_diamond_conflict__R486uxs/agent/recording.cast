[5.210917, "o", "drwxr-xr-x 1 root root 4096 Apr  1 20:58 .\r\ndrwxr-xr-x 1 root root 4096 Apr  1 21:06 ..\r\n-rw-r--r-- 1 root root  481 Apr  1 16:06 Dockerfile\r\n-rw-r--r-- 1 root root 1388 Apr  1 20:57 app.py\r\n-rw-r--r-- 1 root root   30 Apr  1 11:55 entrypoint.sh\r\ndrwxr-xr-x 1 root root 4096 Apr  1 21:06 packages\r\n-rw-r--r-- 1 root root  324 Apr  1 20:57 requirements.txt\r\n"]
[5.211316, "o", "\u001b[?2004hroot@371a193e1ac4:/app# "]
[8.137399, "i", "cat app.py\n"]
[8.137583, "o", "cat app.py\r\n\u001b[?2004l\r"]
[8.139076, "o", "from collections import Counter\r\n\r\nfrom flask import Flask, jsonify, request\r\n\r\nfrom reporting_sdk import build_report_record\r\nfrom telemetry_sdk import encode_event\r\n\r\napp = Flask(__name__)\r\nstored_events = []\r\n\r\n\r\n@app.get(\"/health\")\r\ndef health():\r\n    return jsonify({\"status\": \"ok\"}), 200\r\n\r\n\r\n@app.post(\"/ingest\")\r\ndef ingest():\r\n    payload = request.get_json(silent=True) or {}\r\n    if not payload.get(\"source\") or not payload.get(\"event\"):\r\n        return jsonify({\"error\": \"source and event are required\"}), 400\r\n\r\n    telemetry = encode_event(payload)\r\n    report_record = build_report_record(payload)\r\n\r\n    stored_events.append(\r\n        {\r\n            \"source\": report_record[\"group\"],\r\n            \"event\": telemetry[\"event\"],\r\n            \"user_id\": report_record.get(\"user_id\"),\r\n        }\r\n    )\r\n\r\n    return (\r\n        jsonify(\r\n            {\r\n                \"accepted\": True,\r\n                \"telemetry\": telemetry,\r\n                \"report\": report_record,\r\n            }\r\n        ),\r\n        202,\r\n "]
[8.139143, "o", "   )\r\n\r\n\r\n@app.get(\"/reports/summary\")\r\ndef summary():\r\n    #from summary_sdk import render_summary\r\n\r\n    by_source = Counter(event[\"source\"] for event in stored_events)\r\n    #return jsonify(render_summary(len(stored_events), dict(by_source))), 200\r\n    return jsonify({\"total\": len(stored_events), \"sources\": dict(by_source)}), 200\r\n\r\n\r\nif __name__ == \"__main__\":\r\n    app.run(host=\"0.0.0.0\", port=8000, debug=False)\r\n"]
[8.13953, "o", "\u001b[?2004hroot@371a193e1ac4:/app# "]
