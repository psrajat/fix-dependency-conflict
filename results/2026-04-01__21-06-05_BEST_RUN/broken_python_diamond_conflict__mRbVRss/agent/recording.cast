[88.951925, "o", "cat packages/schema_lib_v1/schema_lib/__init__.py\r\n\u001b[?2004l\r"]
[88.953249, "o", "def normalize_event(payload: dict, *, drop_empty: bool = False) -> dict:\r\n    normalized = {}\r\n    for key, value in payload.items():\r\n        if drop_empty and value in (None, \"\"):\r\n            continue\r\n        normalized[key] = value\r\n    normalized[\"schema_version\"] = \"1.8.2\"\r\n    return normalized\r\n"]
[88.953447, "o", "\u001b[?2004hroot@36a7986e2147:/app# "]
