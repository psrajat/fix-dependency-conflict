[10.204824, "o", "drwxr-xr-x 1 root root 4096 Apr  1 20:58 .\r\ndrwxr-xr-x 1 root root 4096 Apr  1 21:06 ..\r\n-rw-r--r-- 1 root root  481 Apr  1 16:06 Dockerfile\r\n-rw-r--r-- 1 root root 1388 Apr  1 20:57 app.py\r\n-rw-r--r-- 1 root root   30 Apr  1 11:55 entrypoint.sh\r\ndrwxr-xr-x 1 root root 4096 Apr  1 21:06 packages\r\n-rw-r--r-- 1 root root  324 Apr  1 20:57 requirements.txt\r\n"]
