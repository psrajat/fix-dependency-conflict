[89.56779, "o", "def normalize_event(payload: dict, *, drop_empty: bool = False) -> dict:\r\n    normalized = {}\r\n    for key, value in payload.items():\r\n        if drop_empty and value in (None, \"\"):\r\n            continue\r\n        normalized[key] = value\r\n    normalized[\"schema_version\"] = \"1.8.2\"\r\n    return normalized\r\n"]
