[251.723805, "i", "cat packages/telemetry_sdk/telemetry_sdk/encoder.py\n"]
[251.724193, "o", "cat packages/telemetry_sdk/telemetry_sdk/encoder.py\r\n\u001b[?2004l\r"]
[251.726256, "o", "from schema_lib import normalize_event\r\n\r\n\r\ndef encode_event(payload: dict) -> dict:\r\n    normalized = normalize_event(payload)\r\n    return {\r\n        \"channel\": normalized.get(\"source\", \"unknown\"),\r\n        \"event\": normalized[\"event\"],\r\n        \"schema_version\": normalized[\"schema_version\"],\r\n    }\r\n"]
[251.726428, "o", "\u001b[?2004hroot@be855c1f7611:/app# "]
