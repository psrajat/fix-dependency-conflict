[130.200194, "i", "cat packages/schema_lib_v2/schema_lib/__init__.py\n"]
[130.200523, "o", "cat packages/schema_lib_v2/schema_lib/__init__.py\r\n\u001b[?2004l\r"]
[130.202032, "o", "def normalize_event(payload: dict, *, required_fields=()) -> dict:\r\n    missing = [field for field in required_fields if not payload.get(field)]\r\n    if missing:\r\n        raise ValueError(f\"missing required fields: {', '.join(sorted(missing))}\")\r\n\r\n    normalized = dict(payload)\r\n    normalized[\"schema_version\"] = \"2.1.0\"\r\n    return normalized\r\n"]
[130.202492, "o", "\u001b[?2004hroot@93cc3dce2069:/app# "]
[136.568104, "i", "cat packages/schema_lib_v1/schema_lib/__init__.py\n"]
[136.568341, "o", "cat packages/schema_lib_v1/schema_lib/__init__.py\r\n\u001b[?2004l\r"]
[136.569725, "o", "def normalize_event(payload: dict, *, drop_empty: bool = False) -> dict:\r\n    normalized = {}\r\n    for key, value in payload.items():\r\n        if drop_empty and value in (None, \"\"):\r\n            continue\r\n        normalized[key] = value\r\n    normalized[\"schema_version\"] = \"1.8.2\"\r\n    return normalized\r\n"]
