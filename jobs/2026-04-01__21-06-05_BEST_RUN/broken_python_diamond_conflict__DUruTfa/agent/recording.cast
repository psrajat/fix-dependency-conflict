[170.919608, "o", "\u001b[31mERROR: Cannot install -r requirements.txt (line 4), -r requirements.txt (line 6) and schema-lib 1.8.2 (from /app/packages/schema_lib_v1) because these package versions have conflicting dependencies.\u001b[0m\u001b[31m\r\n\u001b[0m"]
[170.92007, "o", "\r\nThe conflict is caused by:\r\n    The user requested schema-lib 1.8.2 (from /app/packages/schema_lib_v1)\r\n    telemetry-sdk 1.4.0 depends on schema-lib<3 and >=1.8\r\n    reporting-sdk 2.2.0 depends on schema-lib 2.1.0 (from /app/packages/schema_lib_v2)\r\n\r\nTo fix this you could try to:\r\n1. loosen the range of package versions you've specified\r\n2. remove package versions to allow pip attempt to solve the dependency conflict\r\n\r\n"]
[170.920417, "o", "\u001b[31mERROR: ResolutionImpossible: for help visit https://pip.pypa.io/en/latest/topics/dependency-resolution/#dealing-with-dependency-conflicts\u001b[0m\u001b[31m\r\n\u001b[0m"]
